# ==========================================================================
# OpenClaw — Environment Variables
# ==========================================================================
# Copy this file to .env and fill in the values before starting:
#   cp .env.example .env
#
# Secrets in this file MUST NOT be committed to version control.
# ==========================================================================

# ── General ───────────────────────────────────────────────────────────────
TZ=America/New_York

# ── Image ─────────────────────────────────────────────────────────────────
# Pin to a dated release tag. Avoid :latest for production stability.
# Check https://github.com/openclaw/openclaw/releases for available tags.
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:2026.4.1

# ── Gateway ───────────────────────────────────────────────────────────────
# Published port on the host (bound to 127.0.0.1 only).
OPENCLAW_GATEWAY_PORT=18789
# Bind mode: lan (reachable from host via published port) or loopback.
# With Docker bridge networking, loopback makes the gateway unreachable
# from the host — use 'lan' and rely on the 127.0.0.1 port binding instead.
OPENCLAW_GATEWAY_BIND=lan
# Auth token for the Control UI and CLI. Generate with:
#   openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# ── Persistent Storage ───────────────────────────────────────────
# Config, credentials, and runtime state.
OPENCLAW_DATA_DIR=/mnt/openclaw/data
# Agent workspace (skills, AGENTS.md, project files).
OPENCLAW_WORKSPACE_DIR=/mnt/openclaw/workspace
# Persistent rolling logs (redirected from ephemeral /tmp/openclaw).
OPENCLAW_LOG_DIR=/mnt/openclaw/logs
# Backup target for scripts/backup.sh snapshots.
OPENCLAW_BACKUP_DIR=/mnt/openclaw/backups

# ── UID/GID ───────────────────────────────────────────────────────────────
# Must match ownership of the RAID6 directories. The official OpenClaw image
# uses uid/gid 1000 (node user).
PUID=1000
PGID=1000

# ── Networking ────────────────────────────────────────────────────────────
# Name of the external Docker network where Ollama is running.
# Default matches the ai-stack compose project network name.
AI_STACK_NETWORK=ai-stack
