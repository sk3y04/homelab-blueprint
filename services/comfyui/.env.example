# ==========================================================================
# ComfyUI — Environment Variables
# ==========================================================================
# Copy this file to .env and fill in the values before starting:
#   cp .env.example .env
#
# Secrets in this file MUST NOT be committed to version control.
# ==========================================================================

# ── General ───────────────────────────────────────────────────────────────
TZ=America/New_York

# Optional: Linux host UID/GID for bind-mounted directory ownership.
# Set these if the container creates root-owned files under COMFYUI_DATA_DIR.
# Example:
# HOST_UID=1000
# HOST_GID=1000
HOST_UID=
HOST_GID=

# ── Data Directory ────────────────────────────────────────────────────────
# Base path for all persistent ComfyUI data (models, outputs, custom nodes).
# Ensure this directory exists and has enough space.
# Space planning:
#   SDXL checkpoints:    ~7 GB each
#   FLUX models:         ~12-24 GB each
#   WAN 2.1 models:      ~15-30 GB each
#   LoRAs:               ~50-500 MB each
#   Output images/video: grows over time
# Minimum recommended: 100 GB.  200 GB+ comfortable.
COMFYUI_DATA_DIR=/opt/comfyui/data

# ── Port ──────────────────────────────────────────────────────────────────
# Published on all host interfaces in docker-compose.yml.
# Reach it from the LAN at http://<host-ip>:${COMFYUI_PORT}
COMFYUI_PORT=8188

# ── Build Arguments ──────────────────────────────────────────────────────
# PyTorch base image.  Determines CUDA version inside the container.
# Verify available tags: https://hub.docker.com/r/pytorch/pytorch/tags
# Choose a tag that matches your NVIDIA driver's supported CUDA runtime.
PYTORCH_IMAGE=pytorch/pytorch:2.10.0-cuda13.0-cudnn9-runtime

# ComfyUI version to clone during image build.
# Use 'master' for latest, or a specific tag/commit for reproducibility.
# Find tags: https://github.com/comfyanonymous/ComfyUI/tags
COMFYUI_VERSION=master

# ── Runtime Arguments ────────────────────────────────────────────────────
# Extra CLI arguments passed to ComfyUI's main.py.
# xformers is auto-detected when installed — no flag needed.
#
# Useful options for RTX 3090:
#   --force-fp16                    Force fp16 precision (saves VRAM, safe on Ampere)
#   --dont-upcast-attention         Further VRAM savings for large models
#   --preview-method auto           Enable live generation previews
#   --use-pytorch-cross-attention   Use PyTorch attention INSTEAD of xformers
#                                   (only if xformers causes issues)
#
# NOT recommended for RTX 3090:
#   --force-fp32                    Wastes VRAM, no benefit
#   --fp8_e4m3fn / --fp8_e5m2      RTX 3090 lacks native FP8 hardware
#
# Example: COMFYUI_EXTRA_ARGS="--force-fp16 --preview-method auto"
COMFYUI_EXTRA_ARGS=
