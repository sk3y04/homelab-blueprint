{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://ollama:11434/v1"
      },
      "models": {
          "qwen3-coder-next": {
            "name": "Qwen3 Coder Next (local)",
          "limit": {
              "context": 256000,
            "output": 8192
          }
        },
        "qwen3.5:27b": {
          "name": "Qwen3.5 27B (local)",
          "limit": {
            "context": 256000,
            "output": 8192
          }
        },
        "qwen3.5:9b": {
          "name": "Qwen3.5 9B (local)",
          "limit": {
            "context": 256000,
            "output": 8192
          }
        },
        "persona": {
          "name": "Persona LoRA (local)",
          "limit": {
            "context": 8192,
            "output": 1024
          }
        },
        "qwen3:32b": {
          "name": "Qwen3 32B (local)",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        },
        "qwen3:14b": {
          "name": "Qwen3 14B (local)",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        }
      }
    }
  },
  "model": "{env:OPENCODE_MODEL}",
  "small_model": "{env:OPENCODE_SMALL_MODEL}",
  "share": "disabled"
}
