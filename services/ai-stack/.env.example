# ==========================================================================
# AI Stack — Environment Variables
# ==========================================================================
# Copy this file to .env and fill in the values before starting:
#   cp .env.example .env
#
# Secrets in this file MUST NOT be committed to version control.
# ==========================================================================

# ── General ───────────────────────────────────────────────────────────────
TZ=America/New_York

# ── Data Directories ──────────────────────────────────────────────────────
# Active AI working set. Prefer SSD storage for current models, checkpoints,
# processed datasets, and active adapter exports.
AI_ACTIVE_DATA_DIR=/opt/ai-stack/data
# Archive / cold storage. HDD RAID is fine for raw exports, archived runs,
# old adapters, and other bulk AI artifacts.
AI_ARCHIVE_DATA_DIR=/mnt/archive/ai-stack

# ── Ollama ────────────────────────────────────────────────────────────────
OLLAMA_PORT=11434
# Max models loaded in VRAM simultaneously. 1 is safest for 24 GB with 32B models.
OLLAMA_MAX_LOADED_MODELS=1
# Parallel request slots. 2 is conservative for 32B models on 24 GB VRAM.
OLLAMA_NUM_PARALLEL=2

# ── Open WebUI ────────────────────────────────────────────────────────────
OPEN_WEBUI_PORT=8080
# Secret key for session encryption. Generate with:
#   openssl rand -hex 32
OPEN_WEBUI_SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
# Set to true for first startup to create admin account, then set to false.
OPEN_WEBUI_ENABLE_SIGNUP=true

# ── OpenClaw ──────────────────────────────────────────────────────────────
OPENCLAW_PORT=8081
# Optional service. Disabled by default unless you start the `openclaw`
# profile explicitly. Published images live on GitHub Container Registry.
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
# Default model for agent tasks.
OPENCLAW_DEFAULT_MODEL=qwen3.5:27b
# After promoting a successful persona run:
# OPENCLAW_DEFAULT_MODEL=persona

# ── OpenCode ───────────────────────────────────────────────────────────────
OPENCODE_PORT=4096
# Basic auth for the OpenCode web UI/API.
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=CHANGE_ME_GENERATE_A_LONG_RANDOM_PASSWORD
# Default primary and lightweight models in provider/model format.
OPENCODE_MODEL=ollama/qwen3-coder-next
OPENCODE_SMALL_MODEL=ollama/qwen3.5:9b
# After promoting a successful persona run:
# OPENCODE_MODEL=ollama/persona

# ── DCGM Exporter ────────────────────────────────────────────────────────
DCGM_EXPORTER_PORT=9400

# ── Training ─────────────────────────────────────────────────────────────
# Verify the image tag before first use. This service only starts with:
#   docker compose --profile training run --rm training
AI_TRAINING_IMAGE=unsloth/unsloth:latest

# Optional llama.cpp checkout for GGUF export tooling.
LLAMA_CPP_DIR=/opt/llama.cpp
