# Stirling Image configuration (example)
# Copy to .env and adjust.

# Ports
STIRLING_IMAGE_HTTP_PORT=1349

# Volumes
STIRLING_IMAGE_DATA_DIR=/path/to/stirling-image/data
STIRLING_IMAGE_WORKSPACE_DIR=/path/to/stirling-image/workspace

# Authentication
AUTH_ENABLED=true
DEFAULT_USERNAME=admin
DEFAULT_PASSWORD=changeme

# Optional application settings
RATE_LIMIT_PER_MIN=100
MAX_UPLOAD_SIZE_MB=100
MAX_BATCH_SIZE=200
CONCURRENT_JOBS=3
MAX_MEGAPIXELS=100
FILE_MAX_AGE_HOURS=24
CLEANUP_INTERVAL_MINUTES=30
APP_NAME=Stirling Image
DEFAULT_THEME=light
DEFAULT_LOCALE=en