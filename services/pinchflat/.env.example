# Pinchflat configuration (example)
# Copy to .env and adjust.

PUID=1000
PGID=1000
TZ=UTC

# Ports
PINCHFLAT_HTTP_PORT=8945

# Volumes
# Recommended layout for Jellyfin: point this at a dedicated YouTube library
# root, then keep Pinchflat's Media Center preset unchanged so files land under
# /shows/<channel>/Season YYYY/...
PINCHFLAT_CONFIG_DIR=/path/to/pinchflat/config
PINCHFLAT_DOWNLOADS_DIR=/path/to/media/youtube

# Optional Pinchflat application settings
LOG_LEVEL=debug
UMASK=022
JOURNAL_MODE=wal
YT_DLP_WORKER_CONCURRENCY=2
BASE_ROUTE_PATH=/

# Optional built-in authentication for the web UI
BASIC_AUTH_USERNAME=
BASIC_AUTH_PASSWORD=

# Optional podcast / RSS feed access outside app auth
EXPOSE_FEED_ENDPOINTS=

# Optional Prometheus metrics on /metrics
ENABLE_PROMETHEUS=