# Monitoring Stack configuration (example)
# Copy to .env and adjust.

TZ=UTC

# Volumes — base directories for persistent data
MONITORING_CONFIG_DIR=/path/to/monitoring/config
MONITORING_DATA_DIR=/path/to/monitoring/data

# Grafana
GRAFANA_HTTP_PORT=3100
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME
GF_SERVER_ROOT_URL=https://grafana.example.com

# Prometheus
PROMETHEUS_PORT=9090

# Loki
LOKI_PORT=3101

# Node Exporter
NODE_EXPORTER_PORT=9100

# NVIDIA GPU Exporter
NVIDIA_SMI_EXPORTER_PORT=9836
NVIDIA_VISIBLE_DEVICES=all
